# ──────────────────────────────────────────────
# tickets-frontend — Variables de entorno
# ──────────────────────────────────────────────
# Copia este archivo a `.env` y ajusta los valores según tu entorno.
# Solo las variables con prefijo VITE_ se exponen al cliente.

# URL base para las peticiones HTTP de Axios.
# - En desarrollo (mismo origen + proxy de Vite): dejar como '/api/v1'.
# - En producción cross-origin: usar la URL absoluta del backend, p. ej.
#   https://api.midominio.com/api/v1
VITE_API_BASE_URL=/api/v1

# Target del proxy de Vite hacia el backend. Solo aplica en `npm run dev`.
VITE_BACKEND_TARGET=http://localhost:8000
